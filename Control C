<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>منصة التحكم الذكية الاحترافية</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #0a0a0f;
            --surface: #13131a;
            --surface2: #1c1c26;
            --border: rgba(255,255,255,0.07);
            --accent: #4a90e2;
            --accent-glow: rgba(74,144,226,0.25);
            --accent-rgb: 74, 144, 226;
            --text: #f0f0f5;
            --text-dim: #6b6b80;
            --text-mid: #a0a0b8;
        }

        /* الثيمات المخصصة */
        .theme-bros {
            --bg: #050508;
            --surface: #0f0f15;
            --surface2: #171722;
            --accent: #a855f7;
            --accent-glow: rgba(168,85,247,0.3);
            --accent-rgb: 168, 85, 247;
        }

        /* ثيم الروبوت الترحيبي الفخم (Neon Cyan & Black) */
        .theme-robot {
            --bg: #030808;
            --surface: #091314;
            --surface2: #102224;
            --accent: #00f2fe;
            --accent-glow: rgba(0,242,254,0.3);
            --accent-rgb: 0, 242, 254;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            letter-spacing: normal !important;
            word-spacing: normal !important;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'Cairo', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            padding: 20px;
            overflow-x: hidden;
            position: relative;
            transition: background 0.4s ease;
            direction: rtl;
        }

        body::before {
            content: '';
            position: fixed;
            top: -200px;
            right: -200px;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
            transition: background 0.6s ease;
            animation: pulse-bg 4s ease-in-out infinite;
        }

        @keyframes pulse-bg {
            0%, 100__ { transform: scale(1); opacity: 1; }
            50__ { transform: scale(1.15); opacity: 0.7; }
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .header-left h1 { font-size: 22px; font-weight: 900; }
        .header-left p { font-size: 13px; color: var(--text-dim); margin-top: 2px; }
        .live-dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            background: #22c55e;
            border-radius: 50%;
            margin-left: 6px;
            box-shadow: 0 0 8px #22c55e;
        }

        .add-btn {
            width: 42px;
            height: 42px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 14px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 18px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .devices-wrapper {
            overflow-x: auto;
            white-space: nowrap;
            margin-bottom: 20px;
            padding-bottom: 5px;
            scrollbar-width: none;
        }
        .devices-wrapper::-webkit-scrollbar { display: none; }
        .devices-bar { display: inline-flex; gap: 10px; }

        .device-pill {
            padding: 10px 18px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 14px;
            font-size: 13px;
            font-weight: 700;
            color: var(--text-dim);
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.16,1,0.3,1);
        }

        .device-pill.active {
            background: rgba(var(--accent-rgb), 0.15);
            border-color: var(--accent);
            color: var(--accent);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px var(--accent-glow);
        }

        .main-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 24px;
            margin-bottom: 20px;
            cursor: pointer;
            box-shadow: 0 0 20px rgba(var(--accent-rgb), 0.15);
        }

        .main-card-inner { display: flex; align-items: center; gap: 20px; }
        .orbit-container { position: relative; width: 80px; height: 80px; flex-shrink: 0; }
        .orbit-ring {
            position: absolute; inset: 0; border-radius: 50%; border: 2px solid transparent;
            border-top-color: var(--accent); animation: spin 2s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        .orbit-core {
            position: absolute; inset: 8px; background: var(--surface2); border-radius: 50%;
            display: flex; justify-content: center; align-items: center; font-size: 12px; font-weight: 900; color: var(--accent);
        }

        .card-info h2 { font-size: 18px; font-weight: 700; }
        .status-row { display: flex; gap: 8px; align-items: center; font-size: 12px; margin-top: 4px; }
        .status-badge { background: rgba(34,197,94,0.15); color: #22c55e; border-radius: 20px; padding: 2px 10px; font-weight: 700; }

        .grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; margin-bottom: 20px; }
        .card {
            background: var(--surface); border: 1px solid var(--border); border-radius: 20px;
            padding: 18px; min-height: 125px; display: flex; flex-direction: column; justify-content: space-between;
            cursor: pointer; transition: all 0.2s;
        }
        .card:active { transform: scale(0.96); }
        .icon-box { width: 44px; height: 44px; border-radius: 12px; display: flex; justify-content: center; align-items: center; font-size: 20px; }
        .card-title { font-size: 15px; font-weight: 700; margin-top: 10px; }
        .card-sub { font-size: 11px; color: var(--text-dim); margin-top: 2px; }

        .network-card {
            background: linear-gradient(135deg, var(--surface) 0%, var(--surface2) 100%);
            border: 1px solid var(--border); border-radius: 20px; padding: 20px; margin-bottom: 20px;
        }
        .network-row { display: flex; justify-content: space-between; align-items: center; margin-top: 12px; font-size: 13px; }
        .net-input {
            background: rgba(0,0,0,0.3); border: 1px solid var(--border); padding: 6px 12px;
            border-radius: 8px; color: #fff; font-family: 'Cairo'; font-size: 12px; text-align: left; width: 140px;
        }

        /* الصفحات الداخلية */
        .sub-page {
            position: fixed; inset: 0; background: var(--bg); z-index: 50;
            transform: translateY(100%); transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            padding: 24px; overflow-y: auto;
        }
        .sub-page.open { transform: translateY(0); }
        .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
        .back-btn { background: var(--surface); border: 1px solid var(--border); padding: 8px 16px; border-radius: 12px; color: var(--text); cursor: pointer; }

        .pass-manager { display: flex; flex-direction: column; gap: 12px; }
        .pass-item {
            background: var(--surface); padding: 14px; border-radius: 14px; border: 1px solid var(--border);
            display: flex; justify-content: space-between; align-items: center;
        }
        .copy-btn { background: var(--accent); color: white; border: none; padding: 6px 12px; border-radius: 8px; font-size: 11px; cursor: pointer; }

        .modal-overlay {
            position: fixed; inset: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(8px);
            z-index: 100; display: flex; align-items: flex-end; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.3s;
        }
        .modal-overlay.open { opacity: 1; pointer-events: all; }
        .modal-sheet { background: var(--surface); border-radius: 28px 28px 0 0; padding: 24px; width: 100%; max-width: 500px; transform: translateY(100%); transition: transform 0.3s ease-out; }
        .modal-overlay.open .modal-sheet { transform: translateY(0); }
        .modal-input { width: 100%; background: var(--surface2); border: 1px solid var(--border); border-radius: 12px; padding: 12px; color: #fff; font-family: 'Cairo'; margin-bottom: 15px; outline: none; }
        .modal-actions { display: flex; gap: 10px; }
        .btn { flex: 1; padding: 12px; border-radius: 12px; border: none; font-family: 'Cairo'; font-weight: bold; cursor: pointer; }
        .btn-primary { background: var(--accent); color: #fff; }
        .btn-ghost { background: var(--surface2); color: var(--text-dim); }
    </style>
</head>
<body>

    <header class="header">
        <div class="header-left">
            <h1>منصة التحكم <span style="color:var(--accent)" id="header-tag">ESP32</span></h1>
            <p><span class="live-dot"></span> نظام الإدارة السحابي الموحد</p>
        </div>
        <div class="add-btn" onclick="openAddDeviceModal()">➕</div>
    </header>

    <div class="devices-wrapper">
        <div class="devices-bar" id="devices-bar-list">
            <div class="device-pill active" id="pill-1" onclick="switchDevice(1)">📡 ESP32</div>
            <div class="device-pill"        id="pill-2" onclick="switchDevice(2)">🟣 BROS</div>
            <div class="device-pill"        id="pill-3" onclick="switchDevice(3)">🤖 الروبوت الترحيبي</div>
            <div class="device-pill" style="border-style: dashed; color: var(--text-dim);" onclick="openAddDeviceModal()">➕ إضافة مشروع جديد</div>
        </div>
    </div>

    <section class="main-card" onclick="rotateDevices()">
        <div class="main-card-inner">
            <div class="orbit-container">
                <div class="orbit-ring"></div>
                <div class="orbit-core" id="device-tag">ESP32</div>
            </div>
            <div class="card-info">
                <h2 id="device-title">المتحكم الأول الأساسي</h2>
                <div class="status-row">
                    <span class="status-badge">أونلاين</span>
                    <span id="conn-type">WiFi &bull; التحكم عن بعد نشط</span>
                </div>
            </div>
        </div>
    </section>

    <main class="grid" id="cards-grid"></main>

    <section class="network-card">
        <h3 style="font-size: 14px; font-weight: 700;">📡 إعدادات الشبكة والـ IP (الربط السحابي)</h3>
        <div class="network-row">
            <span>عنوان الـ IP الخارجي:</span>
            <input type="text" class="net-input" value="192.168.1.50" id="device-ip">
        </div>
    </section>

    <div class="sub-page" id="page-password">
        <div class="page-header">
            <h2>🔑 مدير كلمات المرور الآمن</h2>
            <button class="back-btn" onclick="closeSubPage('page-password')">رجوع ✕</button>
        </div>
        <div class="pass-manager">
            <div class="pass-item">
                <div><strong>حساب مشروعي الـ ESP32</strong><p style="font-size:12px; color:var(--text-dim)">Admin_Panel</p></div>
                <button class="copy-btn" onclick="alert('تم النسخ!')">نسخ 📋</button>
            </div>
        </div>
    </div>

    <div class="sub-page" id="page-robot-config">
        <div class="page-header">
            <h2>🤖 إعدادات الروبوت والـ NFC</h2>
            <button class="back-btn" onclick="closeSubPage('page-robot-config')">رجوع ✕</button>
        </div>
        <div class="pass-manager">
            <div class="pass-item" style="flex-direction: column; align-items: flex-start; gap: 8px;">
                <strong>🗣️ الرسالة الترحيبية الصوتية:</strong>
                <input type="text" class="modal-input" value="مرحباً بك يا محمد، جاري تشغيل السوني" style="margin:0; background: var(--surface2);" id="voice-msg">
            </div>
            <div class="pass-item">
                <div><strong>🕹️ تشغيل الـ PlayStation 5 يدوياً</strong><p style="font-size:12px; color:var(--text-dim)">إرسال أمر تشغيل فوري سحابي عبر الشبكة</p></div>
                <button class="copy-btn" onclick="alert('🎮 تم إرسال أمر التشغيل لجهاز السوني بنجاح!')">تشغيل الآن ⚡</button>
            </div>
            <div class="pass-item" style="flex-direction: column; align-items: flex-start;">
                <strong>📋 آخر العمليات وحسابات الـ NFC:</strong>
                <p style="font-size:12px; color:#22c55e; margin-top:5px;">• بطاقة [محمد] - تم التمرير وتشغيل النظام بنجاح ✓</p>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="add-device-modal" onclick="closeAddDeviceModal(event)">
        <div class="modal-sheet">
            <h3>➕ إضافة مشروع ومتحكم جديد</h3>
            <input class="modal-input" id="new-dev-name" placeholder="مثال: متحكم الغرفة...">
            <input class="modal-input" id="new-dev-tag" placeholder="مثال: ARDUINO...">
            <div class="modal-actions">
                <button class="btn btn-ghost" onclick="document.getElementById('add-device-modal').classList.remove('open')">إلغاء</button>
                <button class="btn btn-primary" onclick="saveNewDevice()">إضافة للمنصة ✓</button>
            </div>
        </div>
    </div>

    <script>
        let currentDevice = 1;

        const devices = {
            1: {
                themeClass: '', accent: '#4a90e2', tag: 'ESP32', name: 'المتحكم الأول الأساسي', conn: 'WiFi &bull; سيرفر التحكم عن بعد نشط',
                shortcuts: [
                    { icon: '🔑', title: 'باسورد', sub: 'إدارة الحسابات وثائق التشفير', targetPage: 'page-password' },
                    { icon: '🤖', title: 'AI', sub: 'مساعد الذكاء الاصطناعي Gemini', targetPage: null }
                ]
            },
            2: {
                themeClass: 'theme-bros', accent: '#a855f7', tag: 'BROS', name: 'نظام ومتحكم BROS', conn: 'Bluetooth &bull; BLE ونظام ربط مخصص',
                shortcuts: [
                    { icon: '🕹️', title: 'التحكم باللوحة', sub: 'إرسال واستقبال الأوامر البرمجية', targetPage: null }
                ]
            },
            3: {
                themeClass: 'theme-robot', accent: '#00f2fe', tag: 'ROBOT', name: 'روبوت الترحيب الذكي', conn: 'WiFi &bull; حساس الـ NFC والمايك نشط',
                shortcuts: [
                    { icon: '⚙️', title: 'إعدادات الروبوت', sub: 'تعديل رسالة الترحيب والـ NFC', targetPage: 'page-robot-config' },
                    { icon: '🎮', title: 'تشغيل السوني', sub: 'التحكم عن بعد في الـ PS5', targetPage: 'page-robot-config' }
                ]
            }
        };

        function switchDevice(id) {
            currentDevice = id;
            const d = devices[id];
            
            document.body.className = d.themeClass;
            document.documentElement.style.setProperty('--accent', d.accent);
            document.getElementById('device-tag').textContent = d.tag;
            document.getElementById('header-tag').textContent = d.tag;
            document.getElementById('device-title').textContent = d.name;
            document.getElementById('conn-type').innerHTML = d.conn;

            document.querySelectorAll('.device-pill').forEach(p => p.classList.remove('active'));
            const activePill = document.getElementById('pill-' + id);
            if(activePill) activePill.classList.add('active');

            renderShortcuts(id);
        }

        function rotateDevices() {
            let next = currentDevice + 1;
            if(!devices[next]) next = 1;
            switchDevice(next);
        }

        function renderShortcuts(id) {
            const grid = document.getElementById('cards-grid');
            grid.innerHTML = '';
            devices[id].shortcuts.forEach(s => {
                const card = document.createElement('div');
                card.className = 'card';
                card.innerHTML = `
                    <div class="icon-box" style="background: rgba(255,255,255,0.05); color: var(--accent);">${s.icon}</div>
                    <div><div class="card-title">${s.title}</div><div class="card-sub">${s.sub}</div></div>
                `;
                card.onclick = () => { if(s.targetPage) openSubPage(s.targetPage); else alert('ميزة قيد التطوير للمتحكم'); };
                grid.appendChild(card);
            });
        }

        function openSubPage(pageId) { document.getElementById(pageId).classList.add('open'); }
        function closeSubPage(pageId) { document.getElementById(pageId).classList.remove('open'); }
        function openAddDeviceModal() { document.getElementById('add-device-modal').classList.add('open'); }
        function closeAddDeviceModal(e) { if(e.target === document.getElementById('add-device-modal')) e.target.classList.remove('open'); }

        let nextDeviceId = 4;
        function saveNewDevice() {
            const name = document.getElementById('new-dev-name').value.trim();
            const tag = document.getElementById('new-dev-tag').value.trim();
            if(!name || !tag) return;

            devices[nextDeviceId] = {
                themeClass: '', accent: '#22c55e', tag: tag, name: name, conn: 'جهاز مخصص مضاف حديثاً',
                shortcuts: [{ icon: '💡', title: 'أداة مخصصة', sub: 'التحكم بالمشروع الجديد', targetPage: null }]
            };

            const bar = document.getElementById('devices-bar-list');
            const newPill = document.createElement('div');
            newPill.className = 'device-pill';
            newPill.id = 'pill-' + nextDeviceId;
            newPill.textContent = '📡 ' + tag;
            
            const currentId = nextDeviceId;
            newPill.onclick = () => switchDevice(currentId);
            bar.insertBefore(newPill, bar.lastElementChild);

            document.getElementById('add-device-modal').classList.remove('open');
            switchDevice(currentId);
            nextDeviceId++;
        }

        switchDevice(1);
    </script>
</body>
</html>
